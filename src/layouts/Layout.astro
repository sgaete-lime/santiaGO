---
import dividerImg from '../assets/Webline.png'; 
import verticalLine from '../assets/Webline-Vertical.png'; 

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>
    </head>
    <body>
        <main>
            <div class="side-line left" style={`--line-url: url(${verticalLine.src});`}></div>
            <div class="side-line right" style={`--line-url: url(${verticalLine.src});`}></div>
            
            <slot />
        </main>
    </body>
</html>

<style is:global>
    :root {
        --accent: #F49677;
        --background: #0a0a0a;
    }

    section {
        padding: 2rem;
    }
    
    html, body {
        background: var(--background);
        color: white;
        margin: 0;
        padding: 0;
        /* This hides the "jitter" that bleeds off the side of the screen */
        overflow-x: hidden; 
    }

    main {
        max-width: 750px;
        width: 100%;
        margin: 0 auto; /* Perfect centering */
        min-height: 100vh;
        
        /* 1. This makes the lines anchor to the edges of THIS box */
        position: relative; 
        
        background: var(--background);
        padding: 0 0rem;
    }

    .side-line {
        /* 2. Absolute keeps them stuck to the column, not the window */
        position: absolute;
        top: 0;
        bottom: 0;
        
        /* 3. We make this wider (80px) so the 40px drawing 
           doesn't get cut off by the edge of the div */
        width: 80px; 
        
        background-color: var(--accent);
        pointer-events: none; /* Let clicks pass through to links */
        z-index: 100;

        /* Mask logic */
        -webkit-mask-image: var(--line-url);
        mask-image: var(--line-url);
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: repeat-y;
        mask-repeat: repeat-y;
        -webkit-mask-position: center;
        mask-position: center;
    }

    .side-line.left {
        /* 4. Align to the left edge of the 750px box, 
           then move it half-way out so it straddles the edge */
        left: 0;
        width:5px;
        transform: translateX(-50%) scaleX(-1);
    }

    .side-line.right {
        /* 5. Align to the right edge of the 750px box, 
           then move it half-way out */
        right: 0;
        width:5px;
        transform: translateX(50%);
    }

    section {
        padding: 4rem 0;
        width: 100%;
    }

    /* Keep them visible but maybe smaller on mobile if needed */
    @media (max-width: 800px) {
        /* If you find them too distracting on small screens, 
           change display to none */
        .side-line { width: 40px; }
    }
</style>