---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/oldheadshot.jpg';
import cornerIcon from '../assets/pfpedit1.png'; // Your new small image
---

<section id="hero" class="hero-container">
  <div class="hero-layout">
    
    <div class="text-side">
      <h1>Your Name</h1>
      <p>Game Designer | Artist | Developer</p>
      
      <nav class="hero-nav">
        <a href="#about" class="nav-button">About</a>
        <a href="#projects" class="nav-button">Projects</a>
        <a href="#portfolio" class="nav-button">Portfolio</a>
        <a href="#contact" class="nav-button">Contact</a>
      </nav>
    </div>

    <div class="image-side">
      <div class="pfp-wrapper">
        <Image src={profilePhoto} alt="Profile Picture" class="profile-pic" />
        
        <Image src={cornerIcon} alt="" class="corner-overlay" />
      </div>
    </div>

  </div>
</section>

<style>
  .hero-container {
    min-height: 30vh; /* Bumped slightly for the side-by-side layout */
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1a1a1a;
    
  }

  .hero-layout {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4rem;
    
    width: 80%;
  }

  /* Text Styling */
  .text-side {
    flex: 1;
    text-align: left;
  }

  .hero-nav {
    margin-top: 1.5rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap; /* Keeps it clean on smaller screens */
  }

  /* Image Styling & Overlay Logic */
  .image-side {
    flex-shrink: 0;
    padding-right: 1rem;
  }

  .pfp-wrapper {
    position: relative; /* This is the anchor point for the absolute overlay */
    width: 180px;
    height: 180px;
  }

  .profile-pic {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .corner-overlay {
    position: absolute;
    bottom: -30px; /* Adjust these to move your 'sticker' around */
    right: -30px;
    width: 100px;   /* Size of your corner doodle */
    rotate: -deg;
    height: auto;
    filter: drop-shadow(-2px -2px 0px #ffffff); /* Gives it a little 'pop' */
        filter: drop-shadow(2px 2px 0px #ffffff); /* Gives it a little 'pop' */
  }

  /* Responsive: Stack them on mobile */
  @media (max-width: 768px) {
    .hero-layout {
      flex-direction: column-reverse;
      text-align: center;
      gap: 2rem;
    }
    .text-side {
      text-align: center;
    }
    .hero-nav {
      justify-content: center;
    }
  }
</style>