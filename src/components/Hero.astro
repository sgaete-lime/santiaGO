---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/oldheadshot.jpg';
import cornerIcon from '../assets/pfpedit1.png'; 
---
<head>
    <link href="https://db.onlinewebfonts.com/c/1b3f9cb78376a36884f3908f37a42c91?family=Tiempos+Text+Regular" rel="stylesheet">
</head>
<section id="hero" class="hero-container">
  <div class="hero-layout">
    
    <div class="text-side">
      <h1 class="hero-name">Santiago Gaete</h1>
      <p class="hero-title">Technical Game Designer</p>
      <p class="hero-title">USC Games</p>
      
      <nav class="hero-nav">
        <a href="#projects" class="nav-button">Projects</a>
        <a href="#about" class="nav-button">About</a>
      </nav>
    </div>

    <div class="image-side">
      <div class="pfp-wrapper">
        <Image src={profilePhoto} alt="Profile Picture" class="profile-pic" />
        <Image src={cornerIcon} alt="" class="corner-overlay" />
      </div>
    </div>

  </div>
</section>

<style>
  .hero-container {
    /* 1. Ensure the container itself is centered in the viewport */
    min-height: 40vh; 
    padding: 0rem 0; 
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .hero-layout {
    display: flex;
    flex-direction: row;
    /* 2. This forces both columns to share the same horizontal center line */
    align-items: center; 
    justify-content: center;
    gap: 6rem;
    width: 100%;
  }

  /* Text Side Adjustments */
  .text-side {
    flex: 0 1 auto;
    text-align: left;
    font-family: "Tiempos Text Regular", Helvetica, Arial, sans-serif;
  }

    p {
      font-size-adjust: 0.7;
    }

  .hero-name {
    /* 3. CRUCIAL: Remove default margins that push the text block down */
    margin: 0; 
    font-size: 2.8rem;
    margin-bottom:1rem;
    line-height: 1;
  }

  .hero-title {
    margin: 0.5rem 0 0 0; /* Only a tiny bit of space between name and title */
    font-size: 1.1rem;
    opacity: 0.8;
        font-family: "Kronshrink", Helvetica, Arial, sans-serif;

  }

  .hero-nav {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Link Styling */
  .nav-button {
    text-decoration: none;
    color: white !important; 
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.2s ease;
  }

  .nav-button:hover {
    background-color: var(--accent);
    color: black !important;
    border-color: var(--accent);
  }

  /* Image Side Adjustments */
  .image-side {
    flex-shrink: 0;
    /* 4. Remove any ghost spacing from the image block */
    line-height: 0; 
  }

  .pfp-wrapper {
    position: relative;
    width: 180px;
    height: 240px; /* Taller portrait look */
  }

  .profile-pic {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 2px solid white;
    /* 5. Block display removes the gap at the bottom of images */
    display: block; 
  }

  .corner-overlay {
    position: absolute;
    bottom: -15px;
    right: -25px;
    rotate:6deg;
    width: 90px;
    height: auto;
    z-index: 10;
    filter: drop-shadow(2px 2px 0px white) drop-shadow(-2px -2px 0px white) 
            drop-shadow(2px -2px 0px white) drop-shadow(-2px 2px 0px white);
  }

  @media (max-width: 768px) {
    .hero-layout {
      flex-direction: column-reverse;
      text-align: center;
      gap: 3rem;
    }
    .text-side { text-align: center; }
    .hero-nav { justify-content: center; }
  }
</style>