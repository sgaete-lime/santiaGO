---
import { Image } from 'astro:assets';
import ProjectLightbox from './ProjectLightbox.svelte';
import dividerImg from '../assets/Webline.png'; // Reusing for hand-drawn buttons

interface Link { label: string; url: string; }
interface MediaItem { type: 'image' | 'video'; src: string; caption?: string; }

interface Props {
  title: string;
  italicIntro?: string; 
  description: string;
  mainImage: ImageMetadata;
  mainImageAlt: string;
  mainCaption?: string;
  links: Link[];
  gallery: MediaItem[];
  reversed?: boolean;
}

const { 
  title, 
  italicIntro, 
  description, 
  mainImage, 
  mainImageAlt, 
  mainCaption, 
  links, 
  gallery, 
  reversed = false 
} = Astro.props;
---

<div class={`project-item ${reversed ? 'reversed' : ''}`}>
  <div class="image-side">
    <ProjectLightbox client:load media={gallery} title={title}>
      <div class="img-wrapper">
        <div class="img-frame">
           <Image src={mainImage} alt={mainImageAlt} class="project-img" />
        </div>
        {mainCaption && <span class="img-caption">{mainCaption}</span>}
      </div>
    </ProjectLightbox>
  </div>

  <div class="text-side">
    <h3>{title}</h3>
    <p>
      {italicIntro && <span class="intro">{italicIntro} </span>}
      <br>
      <br>
      {description}
    </p>
    
    <div class="project-links">
      {links.map((link) => (
        <a href={link.url} class="hand-drawn-button" style={`--line-url: url(${dividerImg.src});`}>
          {link.label}
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .project-item {
    display: flex;
    gap: 2rem;
    margin-bottom: 5rem;
    align-items: flex-start;
    width: 100%;
    box-sizing: border-box;
  }

  /* Swaps sides for variety */
  .project-item.reversed { flex-direction: row-reverse; }

  .image-side { 
    flex: 0 0 320px; /* Forces width to exactly 200px */
    min-width: 0;
  }

  .text-side { 
    flex: 1; 
    min-width: 0; /* Prevents text from pushing past the right margin */
    overflow-wrap: break-word;
    margin-right:4rem;
    font-family: 'Kronshrink', Helvetica, Arial, sans-serif;
  }

  .img-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .img-frame {
    padding: 3px;
    background-color: var(--accent); /* Thin peach border around image */
    line-height: 0;
  }

  .project-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .img-caption {
    font-size: 0.95rem;
    opacity: 0.7;
    font-style: italic;
    line-height: 0.8;
    align-self: center;
  }

  h3 { 
    margin: 0 0 0.5rem 0; 
    font-size: 1.8rem; 
    color: var(--accent);
  }
  
  p { 
    font-size: 1.1rem; 
    line-height: 1.5; 
    color: #ddd; 
    margin: 0;
  }

  .intro {
    font-style: italic;
    font-size:0.99rem;
    line-height: 0.2;

    color: #eee; /* Slightly brighter than main text */
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
  }

  /* The "Hand-Drawn" Button Style */
  .hand-drawn-button {
    position: relative;
    font-size: 1.2rem;
    text-decoration: none;
    color: white;
    padding: 0.5rem 1rem;
    background-color: rgba(255, 255, 255, 0.05);
    transition: transform 0.1s ease;
    
    /* Using a thin border and our mask logic for the "line" feel */
    border: 1px solid var(--accent);
  }

  .hand-drawn-button:hover {
    transform: rotate(-1.5deg) scale(1.05);
    background-color: var(--accent);
    color: black;
  }

  /* Stack layout on mobile */
  @media (max-width: 500px) {
    .project-item, .project-item.reversed {
      flex-direction: column;
      gap: 1rem;
    }
    .image-side {
      width: 100%;
      flex: none;
    }
  }
</style>