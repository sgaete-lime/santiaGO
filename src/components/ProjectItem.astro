---
import { Image } from 'astro:assets';
import ProjectLightbox from './ProjectLightbox.svelte';

interface MediaItem { type: 'image' | 'video'; src: string; caption?: string; }

interface Props {
  title: string;
  italicIntro?: string; 
  description: string;
  mainImage: ImageMetadata;
  mainImageAlt: string;
  mainCaption?: string;
  primaryLink: string; // Changed: Just one link for the title
  gallery: MediaItem[];
  reversed?: boolean;
}

const { 
  title, 
  italicIntro, 
  description, 
  mainImage, 
  mainImageAlt, 
  mainCaption, 
  primaryLink, 
  gallery, 
  reversed = false 
} = Astro.props;
---

<head>
    <link href="https://db.onlinewebfonts.com/c/1b3f9cb78376a36884f3908f37a42c91?family=Tiempos+Text+Regular" rel="stylesheet">
</head>

<div class={`project-item ${reversed ? 'reversed' : ''}`}>
  <div class="image-side">
    <ProjectLightbox client:load media={gallery} title={title}>
      <div class="img-wrapper">
        <div class="img-frame">
           <Image src={mainImage} alt={mainImageAlt} class="project-img" />
        </div>
        {mainCaption && <span class="img-caption">{mainCaption}</span>}
      </div>
    </ProjectLightbox>
  </div>

  <div class="text-side">
    <h3>
      <a href={primaryLink} target="_blank" class="title-link">{title}</a>
    </h3>
    <p>
      {italicIntro && <span class="intro">{italicIntro} </span>}
      <br><br>
      {description}
    </p>
  </div>
</div>

<style>
  .project-item {
    display: flex;
    gap: 2rem;
    margin-bottom: 3.5rem;
    align-items: flex-start;
    width: 100%;
    box-sizing: border-box;
  }

  .project-item.reversed { flex-direction: row-reverse; }

  .image-side { 
    flex: 0 0 320px; 
    min-width: 0;
  }

  .text-side { 
    flex: 1; 
    min-width: 0; 
    margin-top:-0.5rem;
    overflow-wrap: break-word;
    margin-right: 4rem;
    font-family: "Tiempos Text Regular", Helvetica, Arial, sans-serif;
  }

  /* Link styling for the Title */
  .title-link {
    text-decoration: none;
    color: var(--accent);
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
    font-family: "Kronshrink", Helvetica, Arial, sans-serif;
    background-color:#b9606049;
    padding-top:3px;
    padding-right:3px;
    padding-left:3px;
  }

  .title-link:hover {
    opacity: 1;
    background-color: #d27b72a8;
    border-bottom-color: var(--accent);
  }

  .img-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .img-frame {
    padding: 3px;
    background-color: var(--accent);
    line-height: 0;
    transition: transform 0.2s ease;
  }

  .img-frame:hover {
    transform: scale(1.025);
  }

  .project-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .img-caption {
    font-size: 0.95rem;
    opacity: 0.7;
    font-style: italic;
    align-self: center;
    font-family: "Tiempos Text Regular", Helvetica, Arial, sans-serif;
  }

  h3 { 
    margin: 0 0 0.5rem 0; 
    font-size: 1.8rem; 
  }
  
  p { 
    font-size: 1.1rem; 
    line-height: 1.5; 
    color: #ddd; 
    margin: 0;
  }

  .intro {
    font-style: italic;
    font-size: 0.99rem;
    color: #eee;
  }

  @media (max-width: 500px) {
    .project-item, .project-item.reversed {
      flex-direction: column;
      gap: 1rem;
    }
    .image-side {
      width: 100%;
      flex: none;
    }
    .text-side {
        margin-right: 0;
    }
  }
</style>